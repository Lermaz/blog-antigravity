---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "A minimalist blog about technology and productivity." } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | Antigravity Blog</title>
    <ClientRouter />
  </head>
  <body>
    <header class="py-6 border-b border-[var(--color-border)] bg-[var(--color-glass)] backdrop-blur-xl sticky top-0 z-[100]">
      <div class="max-w-[800px] mx-auto px-4 flex justify-between items-center">
        <a href="/" class="text-2xl font-bold text-[var(--color-text-main)] tracking-tighter">A<span class="text-[var(--color-primary)]">G</span></a>
        <nav class="flex gap-6">
          <a href="/" class="font-medium text-[var(--color-text-muted)] text-[0.95rem] hover:text-[var(--color-text-main)]">Home</a>
          <a href="/blog" class="font-medium text-[var(--color-text-muted)] text-[0.95rem] hover:text-[var(--color-text-main)]">Blog</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="text-center py-12 px-4 text-[var(--color-text-muted)] text-[0.85rem] border-t border-[var(--color-border)] mt-16">
      <p>&copy; {new Date().getFullYear()} Antigravity. Built for the future.</p>
    </footer>

  </body>
</html>
