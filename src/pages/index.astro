---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const recentPosts = posts.slice(0, 3);
---

<Layout title="Welcome">
  <section class="text-center py-16 mb-8 mt-8">
    <h1 class="text-[4rem] leading-[1.1] mb-6">Redefining <br/> Productivity.</h1>
    <p class="text-xl text-[var(--color-text-muted)] max-w-[600px] mx-auto">A minimalist exploration of technology, design, and developer efficiency in 2026.</p>
  </section>

  <section class="glass-panel">
    <div class="flex justify-between items-center mb-4">
      <h2>Latest Signals</h2>
      <a href="/blog-antigravity/blog" class="text-[0.95rem] font-medium">View All &rarr;</a>
    </div>
    
    <div class="grid gap-8 grid-cols-1 sm:grid-cols-2">
      {recentPosts.map((post) => (
        <article class="p-6 rounded-lg bg-white/5 border border-transparent transition-all duration-300 hover:bg-[var(--color-primary-glow)] hover:border-[var(--color-border)] hover:-translate-y-0.5">
          <a href={`/blog-antigravity/blog/${post.id}`} class="block no-underline text-inherit group">
            <span class="date-tag">
              {post.data.pubDate.toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'short',
                day: 'numeric',
              })}
            </span>
            <h3 class="text-xl mb-2 text-[var(--color-text-main)] transition-colors duration-300 group-hover:text-[var(--color-primary)]">{post.data.title}</h3>
            <p class="text-[var(--color-text-muted)] text-[0.95rem] line-clamp-2">{post.data.description}</p>
          </a>
        </article>
      ))}
    </div>
  </section>
</Layout>

