---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const recentPosts = posts.slice(0, 3);
---

<Layout title="Welcome">
  <section class="hero mb-8 mt-8">
    <h1>Redefining <br/> Productivity.</h1>
    <p class="subtitle">A minimalist exploration of technology, design, and developer efficiency in 2026.</p>
  </section>

  <section class="latest-posts glass-panel">
    <div class="flex justify-between items-center mb-4">
      <h2>Latest Signals</h2>
      <a href="/blog" class="view-all">View All &rarr;</a>
    </div>
    
    <div class="post-grid">
      {recentPosts.map((post) => (
        <article class="post-card">
          <a href={`/blog/${post.slug}`} class="post-link">
            <span class="date-tag">
              {post.data.pubDate.toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'short',
                day: 'numeric',
              })}
            </span>
            <h3>{post.data.title}</h3>
            <p>{post.data.description}</p>
          </a>
        </article>
      ))}
    </div>
  </section>
</Layout>

<style>
  .hero {
    text-align: center;
    padding: 4rem 0;
  }
  .hero h1 {
    font-size: 4rem;
    line-height: 1.1;
    margin-bottom: 1.5rem;
  }
  .subtitle {
    font-size: 1.25rem;
    color: var(--text-muted);
    max-width: 600px;
    margin: 0 auto;
  }
  .view-all {
    font-size: 0.95rem;
    font-weight: 500;
  }
  .post-grid {
    display: grid;
    gap: 2rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 640px) {
    .post-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  .post-card {
    padding: 1.5rem;
    border-radius: var(--border-radius-sm);
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid transparent;
    transition: all 0.3s var(--transition-fluid);
  }
  .post-card:hover {
    background: var(--color-primary-glow);
    border-color: var(--border-color);
    transform: translateY(-2px);
  }
  .post-card h3 {
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
    color: var(--text-main);
  }
  .post-card p {
    color: var(--text-muted);
    font-size: 0.95rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
